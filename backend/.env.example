PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/placement_management
JWT_SECRET=your_jwt_secret_key_change_in_production
ACCESS_TOKEN_EXPIRE=1h
REFRESH_TOKEN_EXPIRE=7d
LOG_LEVEL=info
REQUEST_TIMEOUT_MS=30000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=30
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=5

# comma-separated (include both localhost and 127.0.0.1 if you use either)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

APP_BASE_URL=http://localhost:3000

# Set to false in production when SMTP is configured
SKIP_EMAIL_VERIFICATION=true

# Mail — if SMTP_PASS is empty, reset/verify links print in the backend terminal
MAIL_FROM=Placement Hub <contentcreationhubbyipos@gmail.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=contentcreationhubbyipos@gmail.com
SMTP_PASS=

# Gmail example (requires App Password, not your normal Gmail password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PASS=your_16_char_app_password

# Cloudinary (resume storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_RESUME_FOLDER=placement/resumes
