{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "management",
  "compatibility_date": "2026-06-29",
  "observability": {
    "enabled": true
  },
  // This field marks the project as a Cloudflare Pages project.
  // It should point to the build output directory of your frontend application.
  "pages_build_output_dir": "frontend/dist",
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
